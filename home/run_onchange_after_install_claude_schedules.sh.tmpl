#!/bin/zsh
# launchd plist の bootstrap を chezmoi apply 時に再実行する
# 以下のハッシュが変わったときに再実行される
# tom-doerr-url-to-x-post.plist hash: {{ include "Library/LaunchAgents/com.claude.schedule.tom-doerr-url-to-x-post.plist.tmpl" | sha256sum }}
# tom-doerr-url-to-x-post run-scheduler.sh hash: {{ include "dot_claude/schedules/tom-doerr-url-to-x-post/executable_run-scheduler.sh" | sha256sum }}
# ob-daily-log.plist hash: {{ include "Library/LaunchAgents/com.claude.schedule.ob-daily-log.plist.tmpl" | sha256sum }}
# ob-daily-log run-scheduler.sh hash: {{ include "dot_claude/schedules/ob-daily-log/executable_run-scheduler.sh" | sha256sum }}

set -eu

UID_NUM="$(id -u)"
DOMAIN="gui/$UID_NUM"

for plist in "$HOME/Library/LaunchAgents/com.claude.schedule."*.plist; do
  [ -f "$plist" ] || continue
  label="$(basename "$plist" .plist)"
  echo "[claude-schedules] reload: $label"
  launchctl bootout "$DOMAIN/$label" 2>/dev/null || true
  launchctl bootstrap "$DOMAIN" "$plist"
  launchctl enable "$DOMAIN/$label" 2>/dev/null || true
done
