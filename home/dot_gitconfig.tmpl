# =============================================================================
# .gitconfig - Git Configuration
# =============================================================================

[user]
    name = {{ if hasKey . "name" }}{{ .name }}{{ else }}Your Name{{ end }}
    email = {{ if hasKey . "email" }}{{ .email }}{{ else }}you@example.com{{ end }}

[color]
    ui = true

[core]
    excludesfile = ~/.gitignore_global
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

[commit]
    template = ~/.gitmessage.txt

[url "ssh://git@github.com/"]
    insteadOf = https://github.com/

{{- if (and (hasKey . "work") .work) }}
{{- /* Set WORK_GITHUB_ORG env var to rewrite https://github.com/<ORG>/ to ssh */}}
{{- $org := env "WORK_GITHUB_ORG" }}
{{- if $org }}
[url "ssh://git@github.com/{{ $org }}/"]
    insteadOf = https://github.com/{{ $org }}/
{{- end }}
{{- end }}

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[ghq]
    root = ~/ghq

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    default = current

[wt]
    remover = trash

[alias]
    wl = worktree list
    wa = worktree add
    wr = worktree remove
    wp = worktree prune
